{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "serve",
            "type": "shell",
            "command": "npx",
            "args": ["-y", "serve", "-l", "8081"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {}
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "serve",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Serving!|localhost"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
